yCAAqC;AAAA,kCAC5CA,YAAiC,QAAA,MAAAG,gBAAxB,MAAM,QAAQ,GAAA,CAAA;AAAA,kCACX,MAAM,YAAY,MAAM,qBAApCL,YAA+D,QAAA;AAAA;oCAArB,OAAM;AAAA,kCAAA,GAAO,GAAC;kCAC5C,MAAM,QAAlBD,UAAA,GAAAC,YAA2D,QAAA,EAAA,KAAA,EAAA,GAAAK,gBAAhC,WAAW,MAAM,IAAI,CAAA,GAAA,CAAA;;gCAGpDH,YAEK,QAFD,OAAM,yCAAA,GAAwCG,gBAC3C,MAAM,KAAK,GAAA,CAAA;AAAA,gCAGH,MAAM,oBAArBL,YAOU,oBAAA;AAAA;kCAPgB,QAAO;AAAA,kCAC5B,OAAO,MAAM,aAAQ,YAAA,WAAA;AAAA,kCAAqC,SAAQ;AAAA,kCACnE,OAAM;AAAA,gCAAA;kCACK,kBACP,MACgG;AAAA,oCADhGE,YACgG,kBAAA;AAAA,sCADzF,MAAK;AAAA,sCACR,OAAM;AAAA,oCAAA;;;;;;;;;;;;;;;;;;;;;;;;;;;;;","names":["_withAsyncContext","_ssrRenderComponent","_mergeProps","_push","_parent","_unref","_","_scopeId","_openBlock","_createBlock","_ssrInterpolate","_createVNode","_Fragment","_renderList","_toDisplayString"],"sources":["../../../../../../../app/pages/speaking.vue"],"sourcesContent":["<script setup lang=\"ts\">\ntype Event = {\n    title: string\n    date: string\n    location: string\n    url?: string\n    category: 'Conference' | 'Live talk' | 'Podcast'\n}\n\nconst { data: page } = await useAsyncData('speaking', () => {\n    return queryCollection('speaking').first()\n})\nif (!page.value) {\n    throw createError({\n        statusCode: 404,\n        statusMessage: 'Page not found',\n        fatal: true\n    })\n}\n\nuseSeoMeta({\n    title: page.value?.seo?.title || page.value?.title,\n    ogTitle: page.value?.seo?.title || page.value?.title,\n    description: page.value?.seo?.description || page.value?.description,\n    ogDescription: page.value?.seo?.description || page.value?.description\n})\n\nconst { global } = useAppConfig()\n\nconst groupedEvents = computed((): Record<Event['category'], Event[]> => {\n    const events = page.value?.events || []\n    const grouped: Record<Event['category'], Event[]> = {\n        'Conference': [],\n        'Live talk': [],\n        'Podcast': []\n    }\n    for (const event of events) {\n        if (grouped[event.category]) grouped[event.category].push(event)\n    }\n    return grouped\n})\n\nfunction formatDate(dateString: string): string {\n    return new Date(dateString).toLocaleDateString('en-US', { year: 'numeric', month: 'long' })\n}\n</script>\n\n<template>\n    <NuxtLayout name=\"default\">\n        <UPage v-if=\"page\">\n            <UPageHero :title=\"page.title\" :description=\"page.description\" :ui=\"{\n                title: '!mx-0 text-left',\n                description: '!mx-0 text-left',\n                links: 'justify-start'\n            }\">\n                <template #links>\n                    <UButton v-if=\"page.links\" :to=\"`mailto:${global.email}`\" v-bind=\"page.links[0]\" />\n                </template>\n            </UPageHero>\n            <UPageSection :ui=\"{\n                container: '!pt-0'\n            }\">\n                <div v-for=\"(eventsInCategory, category) in groupedEvents\" :key=\"category\"\n                    class=\"grid grid-cols-1 lg:grid-cols-3 lg:gap-8 mb-16 last:mb-0\">\n                    <div class=\"lg:col-span-1 mb-4 lg:mb-0\">\n                        <h2 class=\"lg:sticky lg:top-16 text-xl font-semibold tracking-tight text-highlighted\">\n                            {{category.replace(/([A-Z])/g, ' $1').replace(/^./, (str) => str.toUpperCase())}}s\n                        </h2>\n                    </div>\n\n                    <div class=\"lg:col-span-2 space-y-8\">\n                        <div v-for=\"(event, index) in eventsInCategory\" :key=\"`${category}-${index}`\"\n                            class=\"group relative pl-6 border-l border-default\">\n                            <NuxtLink v-if=\"event.url\" :to=\"event.url\" class=\"absolute inset-0\" />\n                            <div class=\"mb-1 text-sm font-medium text-muted\">\n                                <span>{{ event.location }}</span>\n                                <span v-if=\"event.location && event.date\" class=\"mx-1\">·</span>\n                                <span v-if=\"event.date\">{{ formatDate(event.date) }}</span>\n                            </div>\n\n                            <h3 class=\"text-lg font-semibold text-highlighted\">\n                                {{ event.title }}\n                            </h3>\n\n                            <UButton v-if=\"event.url\" target=\"_blank\"\n                                :label=\"event.category === 'Podcast' ? 'Listen' : 'Watch'\" variant=\"link\"\n                                class=\"p-0 pt-2 gap-0\">\n                                <template #trailing>\n                                    <UIcon name=\"i-lucide-arrow-right\"\n                                        class=\"size-4 transition-all opacity-0 group-hover:translate-x-1 group-hover:opacity-100\" />\n                                </template>\n                            </UButton>\n                        </div>\n                    </div>\n                </div>\n            </UPageSection>\n        </UPage>\n    </NuxtLayout>\n</template>\n"],"version":3}